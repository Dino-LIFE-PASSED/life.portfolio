<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Portfolio Tracker' %></title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">
      <span class="nav-logo">&#9682;</span>
      <span class="nav-title">life.portfolio</span>
    </div>
    <div class="nav-links">
      <a href="/" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
      <a href="/add" class="nav-link btn-nav <%= typeof activePage !== 'undefined' && activePage === 'add' ? 'active' : '' %>">+ Add Asset</a>
      <% if (typeof username !== 'undefined' && username) { %>
        <span class="nav-user">&#128100; <%= username %></span>
        <form method="POST" action="/logout" style="display:inline;">
          <button type="submit" class="btn-logout">Logout</button>
        </form>
      <% } %>
    </div>
  </nav>
  <main class="container">
