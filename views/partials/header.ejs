<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Portfolio Tracker' %></title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <% if (typeof bgGifUrl !== 'undefined' && bgGifUrl) { %>
  <style>
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url('<%= bgGifUrl %>');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      z-index: -1;
      opacity: 0.18;
    }
    body { background: #0f0f14; }
    .card, .navbar { background: rgba(26,26,36,0.92); backdrop-filter: blur(10px); }
  </style>
  <% } %>
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">
      <% if (typeof profileImageUrl !== 'undefined' && profileImageUrl) { %>
        <img src="<%= profileImageUrl %>" alt="Profile" class="nav-avatar" />
      <% } else { %>
        <span class="nav-logo">&#9682;</span>
      <% } %>
      <span class="nav-title">life.portfolio</span>
    </div>
    <div class="nav-links">
      <a href="/" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
      <a href="/add" class="nav-link btn-nav <%= typeof activePage !== 'undefined' && activePage === 'add' ? 'active' : '' %>">+ Add</a>
      <% if (typeof username !== 'undefined' && username) { %>
        <button class="btn-profile" onclick="document.getElementById('profileModal').classList.remove('hidden')" title="Profile settings">
          <% if (typeof profileImageUrl !== 'undefined' && profileImageUrl) { %>
            <img src="<%= profileImageUrl %>" alt="Profile" class="btn-profile-img" />
          <% } else { %>
            <span class="btn-profile-initial"><%= username[0].toUpperCase() %></span>
          <% } %>
        </button>
        <form method="POST" action="/logout" style="display:inline;">
          <button type="submit" class="btn-logout">Logout</button>
        </form>
      <% } %>
    </div>
  </nav>

  <% if (typeof username !== 'undefined' && username) { %>
  <!-- Profile Settings Modal -->
  <div id="profileModal" class="modal-overlay hidden" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="modal-card">
      <div class="modal-header">
        <h2 class="modal-title">Profile Settings</h2>
        <button class="modal-close" onclick="document.getElementById('profileModal').classList.add('hidden')">&#10005;</button>
      </div>
      <form method="POST" action="/profile" class="modal-form">
        <div class="form-group">
          <label class="form-label">Profile Image URL</label>
          <input type="text" id="profileImageInput" name="profile_image_url" class="form-input"
            placeholder="Paste any link — webpage or direct image"
            value="<%= typeof profileImageUrl !== 'undefined' && profileImageUrl ? profileImageUrl : '' %>" />
          <p class="form-hint" id="profileImageHint">Paste any URL from Tenor, Giphy, Google Images, etc.</p>
        </div>
        <div class="form-group">
          <label class="form-label">Background GIF URL</label>
          <input type="text" id="bgGifInput" name="bg_gif_url" class="form-input"
            placeholder="Paste any link — webpage or direct image/GIF"
            value="<%= typeof bgGifUrl !== 'undefined' && bgGifUrl ? bgGifUrl : '' %>" />
          <p class="form-hint" id="bgGifHint">Paste any URL from Tenor, Giphy, Behance, etc.</p>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-ghost" onclick="document.getElementById('profileModal').classList.add('hidden')">Cancel</button>
          <button type="submit" id="profileSaveBtn" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
  (function() {
    async function resolveUrl(input, hintEl) {
      const val = input.value.trim();
      if (!val) return;
      hintEl.textContent = 'Resolving...';
      try {
        const r = await fetch('/api/resolve-image?url=' + encodeURIComponent(val));
        const d = await r.json();
        if (d.resolvedUrl && d.resolvedUrl !== val) {
          input.value = d.resolvedUrl;
          hintEl.textContent = '✓ Resolved to direct image URL';
        } else {
          hintEl.textContent = '✓ URL looks good';
        }
      } catch (_) {
        hintEl.textContent = 'Could not resolve — URL saved as-is';
      }
    }

    const profileInput = document.getElementById('profileImageInput');
    const bgInput = document.getElementById('bgGifInput');
    const profileHint = document.getElementById('profileImageHint');
    const bgHint = document.getElementById('bgGifHint');

    if (profileInput) profileInput.addEventListener('blur', () => resolveUrl(profileInput, profileHint));
    if (bgInput) bgInput.addEventListener('blur', () => resolveUrl(bgInput, bgHint));
  })();
  </script>
  <% } %>

  <main class="container">
