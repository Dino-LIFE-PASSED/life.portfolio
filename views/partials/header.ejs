<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Portfolio Tracker' %></title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <% if (typeof hasBgGif !== 'undefined' && hasBgGif) { %>
  <style>
    body { background: #0f0f14; }
    .card, .navbar { background: rgba(26,26,36,0.92); backdrop-filter: blur(10px); }
    #bg-gif {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      opacity: 0.18;
      z-index: -1;
      pointer-events: none;
    }
  </style>
  <% } %>
</head>
<body>
  <% if (typeof hasBgGif !== 'undefined' && hasBgGif) { %>
  <img id="bg-gif" src="/api/profile/bg?t=<%= Date.now() %>" alt="" aria-hidden="true" />
  <% } %>
  <nav class="navbar">
    <div class="nav-brand">
      <% if (typeof hasProfileImage !== 'undefined' && hasProfileImage) { %>
        <img src="/api/profile/avatar?t=<%= Date.now() %>" alt="Profile" class="nav-avatar" />
      <% } else { %>
        <span class="nav-logo">&#9682;</span>
      <% } %>
      <span class="nav-title">life.portfolio</span>
    </div>
    <div class="nav-links">
      <a href="/" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
      <a href="/add" class="nav-link btn-nav <%= typeof activePage !== 'undefined' && activePage === 'add' ? 'active' : '' %>">+ Add</a>
      <% if (typeof username !== 'undefined' && username) { %>
        <button class="btn-profile" onclick="document.getElementById('profileModal').classList.remove('hidden')" title="Profile settings">
          <% if (typeof hasProfileImage !== 'undefined' && hasProfileImage) { %>
            <img src="/api/profile/avatar?t=<%= Date.now() %>" alt="Profile" class="btn-profile-img" />
          <% } else { %>
            <span class="btn-profile-initial"><%= username[0].toUpperCase() %></span>
          <% } %>
        </button>
        <form method="POST" action="/logout" style="display:inline;">
          <button type="submit" class="btn-logout">Logout</button>
        </form>
      <% } %>
    </div>
  </nav>

  <% if (typeof username !== 'undefined' && username) { %>
  <!-- Profile Settings Modal -->
  <div id="profileModal" class="modal-overlay hidden" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="modal-card">
      <div class="modal-header">
        <h2 class="modal-title">Profile Settings</h2>
        <button class="modal-close" onclick="document.getElementById('profileModal').classList.add('hidden')">&#10005;</button>
      </div>
      <form id="profileForm" class="modal-form">
        <div class="form-group">
          <label class="form-label">Profile Image</label>
          <div class="upload-row">
            <input type="text" id="profileImageInput" name="profile_image_url" class="form-input"
              placeholder="Paste a URL or upload a file" value="" />
            <label class="btn btn-ghost btn-sm upload-label" title="Upload from device">
              &#128247; Upload
              <input type="file" accept="image/*,.gif" style="display:none" id="profileImageFile" />
            </label>
          </div>
          <p class="form-hint" id="profileImageHint">URL or upload PNG, JPG, GIF from your device</p>
        </div>
        <div class="form-group">
          <label class="form-label">Background GIF / Image</label>
          <div class="upload-row">
            <input type="text" id="bgGifInput" name="bg_gif_url" class="form-input"
              placeholder="Paste a URL or upload a file" value="" />
            <label class="btn btn-ghost btn-sm upload-label" title="Upload from device">
              &#128247; Upload
              <input type="file" accept="image/*,.gif" style="display:none" id="bgGifFile" />
            </label>
          </div>
          <p class="form-hint" id="bgGifHint">URL or upload GIF/image from your device</p>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-ghost" onclick="document.getElementById('profileModal').classList.add('hidden')">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
  (function() {
    function fileToBase64(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = e => resolve(e.target.result);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    function bindFileUpload(fileInputId, textInputId, hintId) {
      const fileInput = document.getElementById(fileInputId);
      const textInput = document.getElementById(textInputId);
      const hint = document.getElementById(hintId);
      if (!fileInput) return;
      fileInput.addEventListener('change', async () => {
        const file = fileInput.files[0];
        if (!file) return;
        hint.textContent = 'Loading...';
        try {
          const dataUrl = await fileToBase64(file);
          textInput.value = dataUrl;
          hint.textContent = '✓ ' + file.name + ' ready — click Save';
        } catch (_) {
          hint.textContent = 'Failed to load file';
        }
      });
    }

    async function resolveUrl(input, hintEl) {
      const val = input.value.trim();
      if (!val || val.startsWith('data:')) return;
      hintEl.textContent = 'Resolving...';
      try {
        const r = await fetch('/api/resolve-image?url=' + encodeURIComponent(val));
        const d = await r.json();
        if (d.resolvedUrl && d.resolvedUrl !== val) {
          input.value = d.resolvedUrl;
          hintEl.textContent = '✓ Resolved';
        } else {
          hintEl.textContent = '✓ URL looks good';
        }
      } catch (_) {
        hintEl.textContent = 'Saved as-is';
      }
    }

    bindFileUpload('profileImageFile', 'profileImageInput', 'profileImageHint');
    bindFileUpload('bgGifFile', 'bgGifInput', 'bgGifHint');

    // Submit as JSON so base64 '+' characters are never corrupted by URL-encoding
    document.getElementById('profileForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const profileUrl = document.getElementById('profileImageInput').value;
      const bgUrl = document.getElementById('bgGifInput').value;
      const saveBtn = this.querySelector('button[type="submit"]');
      if (saveBtn) { saveBtn.disabled = true; saveBtn.textContent = 'Saving…'; }
      try {
        const r = await fetch('/profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ profile_image_url: profileUrl, bg_gif_url: bgUrl }),
        });
        const d = await r.json();
        if (d.ok) window.location.href = '/?success=Profile+updated';
        else { if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Save'; } }
      } catch (_) {
        if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Save'; }
      }
    });

    const profileInput = document.getElementById('profileImageInput');
    const bgInput = document.getElementById('bgGifInput');
    if (profileInput) profileInput.addEventListener('blur', () => resolveUrl(profileInput, document.getElementById('profileImageHint')));
    if (bgInput) bgInput.addEventListener('blur', () => resolveUrl(bgInput, document.getElementById('bgGifHint')));
  })();
  </script>
  <% } %>

  <main class="container">
