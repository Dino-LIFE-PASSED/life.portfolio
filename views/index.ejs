<%- include('partials/header', { pageTitle: 'Dashboard — life.portfolio', activePage: 'dashboard', username: username, hasProfileImage: hasProfileImage, hasBgGif: hasBgGif }) %>

<%
  function fmt(n) {
    if (n == null) return '—';
    return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function fmtPct(n) {
    if (n == null) return '—';
    return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
  }
  function fmtDollar(n) {
    if (n == null) return '—';
    return (n >= 0 ? '+$' : '-$') + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function signClass(n) {
    if (n == null) return '';
    return n >= 0 ? 'positive' : 'negative';
  }
%>

<div class="page-header">
  <div>
    <h1 class="page-title">Portfolio Dashboard</h1>
    <p class="page-subtitle">Track your investments in real time &nbsp;<span class="live-badge">&#9679; LIVE</span></p>
  </div>
  <button id="thbToggle" class="btn btn-ghost btn-sm" style="font-size:13px;">Show in THB</button>
</div>

<% if (error) { %>
  <div class="alert alert-error"><span>&#9888;</span> <%= error %></div>
<% } %>
<% if (success) { %>
  <div class="alert alert-success"><span>&#10003;</span> <%= success %></div>
<% } %>

<!-- Summary Cards -->
<section class="summary-grid">
  <div class="card summary-card">
    <p class="card-label">Total Invested</p>
    <p class="card-value" id="card-total-invested">$<%= fmt(summary.total_invested) %></p>
    <p class="card-sub"><%= summary.asset_count %> asset<%= summary.asset_count !== 1 ? 's' : '' %></p>
  </div>
  <div class="card summary-card">
    <p class="card-label">Portfolio Value</p>
    <p class="card-value" id="card-total-value">$<%= fmt(summary.total_value) %></p>
    <p class="card-sub">Assets + wallets</p>
  </div>
  <div class="card summary-card">
    <p class="card-label">Wallet Holdings</p>
    <p class="card-value" id="card-wallet-value"><%
      const walletUsd = wallets.reduce((s, w) => s + (w.usd_value || 0), 0);
    %>$<%= fmt(walletUsd) %></p>
    <p class="card-sub"><%= wallets.length %> wallet<%= wallets.length !== 1 ? 's' : '' %></p>
  </div>
  <div class="card summary-card">
    <p class="card-label">Total Return ($)</p>
    <p class="card-value <%= signClass(summary.total_return_dollar) %>" id="card-return-dollar"><%= fmtDollar(summary.total_return_dollar) %></p>
    <p class="card-sub">Unrealized P&amp;L</p>
  </div>
  <div class="card summary-card">
    <p class="card-label">Total Return (%)</p>
    <p class="card-value <%= signClass(summary.total_return_pct) %>" id="card-return-pct"><%= fmtPct(summary.total_return_pct) %></p>
    <p class="card-sub">Overall performance</p>
  </div>
</section>

<% if (assets.length === 0) { %>
  <div class="card" style="text-align:center;padding:48px 24px;">
    <p style="color:var(--text-muted);margin-bottom:20px;font-size:0.95rem;">No holdings yet. Start tracking your portfolio.</p>
    <a href="/add" class="btn btn-primary">+ Add Your First Asset</a>
  </div>
<% } else { %>

<section class="dashboard-grid">

    <!-- Assets Table -->
    <div class="card table-card">
      <div class="card-header">
        <h2 class="card-title">Holdings</h2>
      </div>
      <div class="table-wrapper">
        <table class="assets-table">
          <thead>
            <tr>
              <th></th>
              <th>Name</th>
              <th>Ticker</th>
              <th>Type</th>
              <th class="num">Qty</th>
              <th class="num">Buy Price</th>
              <th class="num">Cur. Price</th>
              <th class="num">Cur. Value</th>
              <th class="num">Return $</th>
              <th class="num">Return %</th>
            </tr>
          </thead>
          <tbody>
            <% assets.forEach(function(a) { %>
            <tr data-asset-id="<%= a.id %>" data-buy-price="<%= a.buy_price %>" data-quantity="<%= a.quantity %>"<% if (a.is_wallet_btc) { %> data-auto-btc="1"<% } %>>
              <td class="action-col">
                <% if (!a.is_wallet_btc) { %>
                <form action="/delete/<%= a.id %>" method="POST" onsubmit="return confirm('Delete <%= a.name %>?')" style="display:inline">
                  <button type="submit" class="btn-delete" title="Delete">&#10005;</button>
                </form>
                <% } %>
                <a href="/edit/<%= a.id %>" class="btn-edit" title="Edit">&#9998;</a>
              </td>
              <td class="asset-name"><%= a.name %><% if (a.is_wallet_btc) { %> <span class="auto-btc-badge">wallet</span><% } %></td>
              <td><span class="ticker-badge"><%= a.ticker %></span></td>
              <td><span class="type-badge type-<%= a.asset_type %>"><%= a.asset_type.toUpperCase() %></span></td>
              <td class="num"><%= a.quantity.toFixed(8) %></td>
              <td class="num cell-buy-price"><% if (a.is_wallet_btc && a.buy_price === 0) { %><a href="/edit/<%= a.id %>" class="set-cost-link">Set cost</a><% } else { %>$<%= fmt(a.buy_price) %><% } %></td>
              <td class="num cell-cur-price"><%= a.current_price != null ? '$' + fmt(a.current_price) : '—' %></td>
              <td class="num cell-cur-value"><%= a.current_value != null ? '$' + fmt(a.current_value) : '—' %></td>
              <td class="num cell-return-dollar <%= signClass(a.return_dollar) %>"><%= fmtDollar(a.return_dollar) %></td>
              <td class="num cell-return-pct <%= signClass(a.return_pct) %>"><%= fmtPct(a.return_pct) %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Allocation Chart -->
    <div class="card chart-card">
      <div class="card-header">
        <h2 class="card-title">Allocation</h2>
      </div>
      <div class="chart-wrapper">
        <canvas id="allocationChart"></canvas>
      </div>
      <ul class="chart-legend" id="chartLegend"></ul>
    </div>

  </section>

<% } %><!-- end else (assets exist) -->

<!-- Bitcoin Wallets Section -->
<section class="wallets-section">
  <div class="card table-card">
    <div class="card-header">
      <h2 class="card-title">&#8383; Bitcoin Wallets</h2>
      <div style="display:flex;gap:8px;align-items:center;">
        <% if (wallets.length > 0) { %>
        <button id="walletViewToggle" class="btn btn-sm btn-ghost" title="Cycle wallet view"></button>
        <% } %>
        <button class="btn btn-sm btn-primary" onclick="document.getElementById('wallet-form').classList.toggle('hidden')">+ Add Wallet</button>
      </div>
    </div>

    <div id="wallet-form" class="wallet-add-form hidden">
      <form action="/wallet/add" method="POST" class="inline-form">
        <input type="text" name="label" class="form-input" placeholder="Label (e.g. Cold Wallet)" required />
        <input type="text" name="address" class="form-input" placeholder="Bitcoin address or xPub/yPub/zPub" required style="flex:2" />
        <button type="submit" class="btn btn-primary">Add</button>
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('wallet-form').classList.add('hidden')">Cancel</button>
      </form>
      <p style="font-size:12px;color:var(--text-dim);margin-top:6px;padding:0 4px;">
        Single address (bc1..., 1..., 3...) or extended public key (xpub..., ypub..., zpub...). xPub scans all derived addresses automatically.
      </p>
    </div>

    <% if (wallets.length === 0) { %>
      <p class="wallet-empty">No wallets tracked yet. Add a Bitcoin address or xPub above.</p>
    <% } else { %>
    <div id="wallets-table-wrapper" class="table-wrapper" data-wallet-mode="both">
      <table class="assets-table">
        <thead>
          <tr>
            <th></th>
            <th>Label</th>
            <th>Source</th>
            <th class="num col-btc-balance">BTC Balance</th>
            <th class="num col-btc-unconfirmed">Unconfirmed</th>
            <th class="num col-wallet-usd">Value</th>
          </tr>
        </thead>
        <tbody id="wallets-tbody">
          <% wallets.forEach(function(w) { %>
          <tr data-wallet-id="<%= w.id %>">
            <td class="action-col">
              <form action="/wallet/delete/<%= w.id %>" method="POST" onsubmit="return confirm('Remove <%= w.label %>?')" style="display:inline">
                <button type="submit" class="btn-delete" title="Remove">&#10005;</button>
              </form>
              <button class="btn-edit" title="Edit" onclick="openWalletEdit(<%= w.id %>, '<%= w.label.replace(/'/g, "\\'") %>')">&#9998;</button>
            </td>
            <td class="asset-name" id="wallet-label-<%= w.id %>"><%= w.label %></td>
            <td>
              <% if (/^[xyz]pub/.test(w.address)) { %>
                <span class="ticker-badge" title="<%= w.address %>">xPub ···<%= w.address.slice(-6) %></span>
              <% } else { %>
                <span class="wallet-addr"><%= w.address.slice(0,8) %>…<%= w.address.slice(-6) %></span>
              <% } %>
            </td>
            <% var neverScanned = /^[xyz]pub/.test(w.address) && w.btc_balance == null; %>
            <td class="num cell-btc-balance col-btc-balance"><%= w.btc_balance != null ? w.btc_balance.toFixed(8) : (neverScanned ? 'Scanning…' : '—') %></td>
            <td class="num cell-btc-unconfirmed col-btc-unconfirmed" style="color:var(--text-dim)"><%= w.btc_unconfirmed != null ? w.btc_unconfirmed.toFixed(8) : '—' %></td>
            <td class="num cell-wallet-usd col-wallet-usd"><%= w.usd_value != null ? '$' + w.usd_value.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}) : (neverScanned ? 'Scanning…' : '—') %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</section>

<script type="application/json" id="chartData"><%- JSON.stringify({ labels: chart.labels, values: chart.values }) %></script>
<script type="application/json" id="walletData"><%- JSON.stringify(wallets.map(w => ({ id: w.id, usd: w.usd_value }))) %></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
// Shared currency state — read by chart tooltip at hover time
window._currency = { showThb: false, usdToThb: null };
window._hasBtcAsset = <%- JSON.stringify(hasBtcAsset) %>;
(function () {
  const chartData = JSON.parse(document.getElementById('chartData').textContent);
  const labels = chartData.labels;
  const values = chartData.values;
  if (!labels.length) return;
  const COLORS = [
    '#6c63ff','#00e676','#ff9100','#00b0ff','#ff4081',
    '#69f0ae','#ffea00','#40c4ff','#ea80fc','#ff6d00',
    '#b2ff59','#f50057','#18ffff','#ffab40','#e040fb'
  ];
  const ctx = document.getElementById('allocationChart');
  if (!ctx) return;
  const total = values.reduce((s, v) => s + v, 0);
  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels,
      datasets: [{ data: values, backgroundColor: COLORS.slice(0, labels.length), borderColor: '#0f0f14', borderWidth: 3, hoverOffset: 8 }]
    },
    options: {
      responsive: true, maintainAspectRatio: true, cutout: '62%',
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: function(ctx) {
          const usd = ctx.parsed;
          const pct = total > 0 ? ((usd / total) * 100).toFixed(1) : 0;
          if (window._currency.showThb && window._currency.usdToThb) {
            const thb = usd * window._currency.usdToThb;
            return ` ฿${thb.toLocaleString('en-US', {maximumFractionDigits: 0})} (${pct}%)`;
          }
          return ` $${usd.toLocaleString('en-US', {minimumFractionDigits: 2})} (${pct}%)`;
        }}}
      }
    }
  });
  const legend = document.getElementById('chartLegend');
  labels.forEach((label, i) => {
    const pct = total > 0 ? ((values[i] / total) * 100).toFixed(1) : 0;
    const li = document.createElement('li');
    li.innerHTML = `<span class="legend-dot" style="background:${COLORS[i%COLORS.length]}"></span><span class="legend-label">${label}</span><span class="legend-pct">${pct}%</span>`;
    legend.appendChild(li);
  });
})();
</script>

<script>
(function () {
  // ─── Currency state ───────────────────────────────────────────────────────
  let usdToThb = null;
  let showThb = false;

  const thbBtn = document.getElementById('thbToggle');

  async function fetchRate() {
    try {
      const r = await fetch('/api/rates');
      if (!r.ok) return;
      const d = await r.json();
      usdToThb = d.usdToThb;
      window._currency.usdToThb = usdToThb;
    } catch (_) {}
  }

  thbBtn.addEventListener('click', async () => {
    if (!usdToThb) await fetchRate();
    if (!usdToThb) return;
    showThb = !showThb;
    window._currency.showThb = showThb;
    localStorage.setItem('preferredCurrency', showThb ? 'thb' : 'usd');
    thbBtn.textContent = showThb ? 'Show in USD' : 'Show in THB';
    renderAllValues();
  });

  // Restore saved currency preference
  if (localStorage.getItem('preferredCurrency') === 'thb') {
    fetchRate().then(() => {
      if (!usdToThb) return;
      showThb = true;
      window._currency.showThb = true;
      thbBtn.textContent = 'Show in USD';
      renderAllValues();
    });
  }

  // Auto-fade alerts after 30 seconds
  document.querySelectorAll('.alert').forEach(function(el) {
    setTimeout(function() {
      el.style.transition = 'opacity 0.8s ease, margin 0.8s ease, padding 0.8s ease, max-height 0.8s ease';
      el.style.opacity = '0';
      el.style.maxHeight = '0';
      el.style.padding = '0';
      el.style.marginBottom = '0';
      el.style.overflow = 'hidden';
    }, 30000);
  });

  // ─── Formatters ───────────────────────────────────────────────────────────
  function fmtMoney(usdVal) {
    if (usdVal == null) return '—';
    if (showThb && usdToThb) {
      const thb = usdVal * usdToThb;
      return '฿' + thb.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }
    return '$' + usdVal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function fmtReturn(usdVal) {
    if (usdVal == null) return '—';
    const val = showThb && usdToThb ? usdVal * usdToThb : usdVal;
    const sym = showThb ? '฿' : '$';
    return (val >= 0 ? '+' + sym : '-' + sym) + Math.abs(val).toLocaleString('en-US', { minimumFractionDigits: showThb ? 0 : 2, maximumFractionDigits: showThb ? 0 : 2 });
  }
  function fmtPct(n) {
    if (n == null) return '—';
    return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
  }

  // ─── Live data stores ─────────────────────────────────────────────────────
  let assetRows = {}; // id → { curValue, retDollar, retPct, buyPrice, qty }
  // Pre-seed wallet values from server-rendered data so first render is correct
  const _walletSeed = JSON.parse(document.getElementById('walletData').textContent);
  let walletRows = {};
  _walletSeed.forEach(w => { if (w.usd != null) walletRows[w.id] = w.usd; });
  let totalInvested = 0;

  function renderAllValues() {
    let assetTotalFull = 0;  // all assets incl. auto BTC (for portfolio value)
    let assetTotalPnl = 0;   // only assets with known cost (for P&L)
    document.querySelectorAll('tr[data-asset-id]').forEach(row => {
      const id = row.dataset.assetId;
      const d = assetRows[id];
      if (!d) return;
      const buyPriceRaw = parseFloat(row.dataset.buyPrice);
      const isAutoBtcNoCost = row.dataset.autoBtc && buyPriceRaw === 0;
      assetTotalFull += d.curValue || 0;
      if (!isAutoBtcNoCost) assetTotalPnl += d.curValue || 0;
      if (d.curPrice != null) row.querySelector('.cell-cur-price').textContent = fmtMoney(d.curPrice);
      if (d.curValue != null) row.querySelector('.cell-cur-value').textContent = fmtMoney(d.curValue);
      // Convert buy price (skip auto BTC "Set cost" placeholder)
      const buyCell = row.querySelector('.cell-buy-price');
      if (buyCell && !isAutoBtcNoCost) buyCell.textContent = fmtMoney(buyPriceRaw);
      if (d.retDollar != null) {
        const rdCell = row.querySelector('.cell-return-dollar');
        rdCell.textContent = fmtReturn(d.retDollar);
        rdCell.className = 'num cell-return-dollar ' + (d.retDollar >= 0 ? 'positive' : 'negative');
      }
      if (d.retPct != null) {
        const rpCell = row.querySelector('.cell-return-pct');
        rpCell.textContent = fmtPct(d.retPct);
        rpCell.className = 'num cell-return-pct ' + (d.retPct >= 0 ? 'positive' : 'negative');
      }
    });

    let walletTotal = 0;
    document.querySelectorAll('tr[data-wallet-id]').forEach(row => {
      const id = row.dataset.walletId;
      const usd = walletRows[id];
      if (usd != null) {
        walletTotal += usd;
        row.querySelector('.cell-wallet-usd').textContent = fmtMoney(usd);
      }
    });

    // If auto BTC asset exists, its value already includes wallet BTC — skip wallet total
    // in portfolio value to avoid double-counting. Wallet Holdings card still shows it.
    const portfolioValue = assetTotalFull + (window._hasBtcAsset ? 0 : walletTotal);
    const retDollar = assetTotalPnl - totalInvested;
    const retPct = totalInvested > 0 ? (retDollar / totalInvested) * 100 : 0;

    const cardInvested = document.getElementById('card-total-invested');
    const cardTotal = document.getElementById('card-total-value');
    const cardWallet = document.getElementById('card-wallet-value');
    const cardRetDollar = document.getElementById('card-return-dollar');
    const cardRetPct = document.getElementById('card-return-pct');

    if (cardInvested) cardInvested.textContent = fmtMoney(totalInvested);
    if (cardTotal) cardTotal.textContent = fmtMoney(portfolioValue);
    if (cardWallet) cardWallet.textContent = fmtMoney(walletTotal);
    if (cardRetDollar) {
      cardRetDollar.textContent = fmtReturn(retDollar);
      cardRetDollar.className = 'card-value ' + (retDollar >= 0 ? 'positive' : 'negative');
    }
    if (cardRetPct) {
      cardRetPct.textContent = fmtPct(retPct);
      cardRetPct.className = 'card-value ' + (retPct >= 0 ? 'positive' : 'negative');
    }

    // Live tab title — shows total return so you can monitor at a glance
    if (totalInvested > 0) {
      document.title = fmtReturn(retDollar) + ' (' + fmtPct(retPct) + ') · life.portfolio';
    }
  }

  // ─── Price polling ────────────────────────────────────────────────────────
  async function refreshPrices() {
    let data;
    try {
      const res = await fetch('/api/prices?t=' + Date.now());
      if (!res.ok) throw new Error('bad status');
      data = await res.json();
    } catch (e) {
      setTimeout(refreshPrices, 5000);
      return;
    }

    totalInvested = 0;
    document.querySelectorAll('tr[data-asset-id]').forEach(row => {
      const id = row.dataset.assetId;
      const buyPrice = parseFloat(row.dataset.buyPrice);
      const qty = parseFloat(row.dataset.quantity);
      const isAutoBtcNoCost = row.dataset.autoBtc && buyPrice === 0;
      if (!isAutoBtcNoCost) totalInvested += qty * buyPrice;
      const entry = data[id];
      if (!entry || entry.price == null) return;
      const curValue = qty * entry.price;
      if (isAutoBtcNoCost) {
        assetRows[id] = { curPrice: entry.price, curValue, retDollar: null, retPct: null };
      } else {
        const retDollar = curValue - (qty * buyPrice);
        const retPct = ((entry.price - buyPrice) / buyPrice) * 100;
        assetRows[id] = { curPrice: entry.price, curValue, retDollar, retPct };
      }
    });

    renderAllValues();
    setTimeout(refreshPrices, 30000);
  }

  // ─── Wallet polling ───────────────────────────────────────────────────────
  async function refreshWallets() {
    let data;
    try {
      const res = await fetch('/api/wallets?t=' + Date.now());
      if (!res.ok) throw new Error('bad status');
      data = await res.json();
    } catch (e) {
      setTimeout(refreshWallets, 30000);
      return;
    }

    data.forEach(w => {
      const row = document.querySelector(`tr[data-wallet-id="${w.id}"]`);
      if (!row) return;
      if (w.btc != null) row.querySelector('.cell-btc-balance').textContent = w.btc.toFixed(8);
      if (w.unconfirmed != null) row.querySelector('.cell-btc-unconfirmed').textContent = w.unconfirmed.toFixed(8);
      if (w.usd != null) walletRows[w.id] = w.usd;
    });

    renderAllValues();
    setTimeout(refreshWallets, 60000);
  }

  refreshPrices();
  refreshWallets();

  // Strip ?success / ?error from URL so reloading doesn't re-show the alert
  if (window.location.search) history.replaceState(null, '', window.location.pathname);
})();
</script>

<script>
(function() {
  const MODES = ['both', 'btc', 'usd'];
  const LABELS = ['BTC + Value', 'BTC Only', 'Value Only'];
  let modeIdx = parseInt(localStorage.getItem('walletViewMode') || '0', 10);
  if (isNaN(modeIdx) || modeIdx < 0 || modeIdx > 2) modeIdx = 0;
  const wrapper = document.getElementById('wallets-table-wrapper');
  const btn = document.getElementById('walletViewToggle');
  function applyMode() {
    if (wrapper) wrapper.dataset.walletMode = MODES[modeIdx];
    if (btn) btn.textContent = LABELS[modeIdx];
    localStorage.setItem('walletViewMode', modeIdx);
  }
  if (btn) btn.addEventListener('click', function() { modeIdx = (modeIdx + 1) % 3; applyMode(); });
  applyMode();
})();
</script>

<!-- Wallet Edit Modal -->
<div id="walletEditModal" class="modal-overlay hidden" onclick="if(event.target===this)this.classList.add('hidden')">
  <div class="modal-card">
    <div class="modal-header">
      <h2 class="modal-title">Edit Wallet</h2>
      <button class="modal-close" onclick="document.getElementById('walletEditModal').classList.add('hidden')">&#10005;</button>
    </div>
    <form id="walletEditForm" class="modal-form">
      <input type="hidden" id="walletEditId" />
      <div class="form-group">
        <label class="form-label">Label</label>
        <input type="text" id="walletEditLabel" class="form-input" placeholder="e.g. Cold Wallet" required />
      </div>
      <p id="walletEditError" style="color:#ff4560;font-size:13px;min-height:18px;"></p>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('walletEditModal').classList.add('hidden')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<script>
function openWalletEdit(id, label) {
  document.getElementById('walletEditId').value = id;
  document.getElementById('walletEditLabel').value = label;
  document.getElementById('walletEditError').textContent = '';
  document.getElementById('walletEditModal').classList.remove('hidden');
  document.getElementById('walletEditLabel').focus();
}

document.getElementById('walletEditForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const id = document.getElementById('walletEditId').value;
  const label = document.getElementById('walletEditLabel').value.trim();
  const btn = this.querySelector('button[type="submit"]');
  const err = document.getElementById('walletEditError');
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const r = await fetch(`/wallet/edit/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ label }),
    });
    const d = await r.json();
    if (d.ok) {
      document.getElementById(`wallet-label-${id}`).textContent = label;
      document.getElementById('walletEditModal').classList.add('hidden');
    } else {
      err.textContent = d.error || 'Save failed';
    }
  } catch (ex) {
    err.textContent = 'Error: ' + ex.message;
  }
  btn.disabled = false; btn.textContent = 'Save';
});
</script>

