<%- include('partials/header', { pageTitle: 'Dashboard — life.portfolio', activePage: 'dashboard' }) %>

<%
  function fmt(n) {
    if (n == null) return '—';
    return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function fmtPct(n) {
    if (n == null) return '—';
    return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
  }
  function fmtDollar(n) {
    if (n == null) return '—';
    return (n >= 0 ? '+$' : '-$') + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function signClass(n) {
    if (n == null) return '';
    return n >= 0 ? 'positive' : 'negative';
  }
%>

<div class="page-header">
  <div>
    <h1 class="page-title">Portfolio Dashboard</h1>
    <p class="page-subtitle">Track your investments in real time &nbsp;<span class="live-badge">&#9679; LIVE</span> <span id="live-status" style="font-size:11px;color:var(--text-dim)"></span></p>
  </div>
</div>

<% if (error) { %>
  <div class="alert alert-error"><span>&#9888;</span> <%= error %></div>
<% } %>
<% if (success) { %>
  <div class="alert alert-success"><span>&#10003;</span> <%= success %></div>
<% } %>

<!-- Summary Cards -->
<section class="summary-grid">
  <div class="card summary-card">
    <p class="card-label">Total Invested</p>
    <p class="card-value">$<%= fmt(summary.total_invested) %></p>
    <p class="card-sub"><%= summary.asset_count %> asset<%= summary.asset_count !== 1 ? 's' : '' %></p>
  </div>
  <div class="card summary-card">
    <p class="card-label">Portfolio Value</p>
    <p class="card-value" id="card-total-value">$<%= fmt(summary.total_value) %></p>
    <p class="card-sub">Assets + wallets</p>
  </div>
  <div class="card summary-card">
    <p class="card-label">Wallet Holdings</p>
    <p class="card-value" id="card-wallet-value"><%
      const walletUsd = wallets.reduce((s, w) => s + (w.usd_value || 0), 0);
    %>$<%= fmt(walletUsd) %></p>
    <p class="card-sub"><%= wallets.length %> wallet<%= wallets.length !== 1 ? 's' : '' %></p>
  </div>
  <div class="card summary-card">
    <p class="card-label">Total Return ($)</p>
    <p class="card-value <%= signClass(summary.total_return_dollar) %>" id="card-return-dollar"><%= fmtDollar(summary.total_return_dollar) %></p>
    <p class="card-sub">Unrealized P&amp;L</p>
  </div>
  <div class="card summary-card">
    <p class="card-label">Total Return (%)</p>
    <p class="card-value <%= signClass(summary.total_return_pct) %>" id="card-return-pct"><%= fmtPct(summary.total_return_pct) %></p>
    <p class="card-sub">Overall performance</p>
  </div>
</section>

<% if (assets.length === 0) { %>
  <!-- Empty state -->
  <section class="empty-state card">
    <div class="empty-icon">&#128200;</div>
    <h2>No assets yet</h2>
    <p>Start building your portfolio by adding your first investment.</p>
    <a href="/add" class="btn btn-primary">+ Add Your First Asset</a>
  </section>
<% } else { %>

  <!-- Main content: table + chart -->
  <section class="dashboard-grid">

    <!-- Assets Table -->
    <div class="card table-card">
      <div class="card-header">
        <h2 class="card-title">Holdings</h2>
        <a href="/add" class="btn btn-sm btn-primary">+ Add Asset</a>
      </div>
      <div class="table-wrapper">
        <table class="assets-table">
          <thead>
            <tr>
              <th></th>
              <th>Name</th>
              <th>Ticker</th>
              <th>Type</th>
              <th class="num">Qty</th>
              <th class="num">Buy Price</th>
              <th class="num">Cur. Price</th>
              <th class="num">Cur. Value</th>
              <th class="num">Return $</th>
              <th class="num">Return %</th>
              <th class="num">Updated</th>
            </tr>
          </thead>
          <tbody>
            <% assets.forEach(function(a) { %>
            <tr data-asset-id="<%= a.id %>" data-buy-price="<%= a.buy_price %>" data-quantity="<%= a.quantity %>">
              <td class="action-col">
                <form action="/delete/<%= a.id %>" method="POST" onsubmit="return confirm('Delete <%= a.name %>?')" style="display:inline">
                  <button type="submit" class="btn-delete" title="Delete">&#10005;</button>
                </form>
                <a href="/edit/<%= a.id %>" class="btn-edit" title="Edit">&#9998;</a>
              </td>
              <td class="asset-name"><%= a.name %></td>
              <td><span class="ticker-badge"><%= a.ticker %></span></td>
              <td><span class="type-badge type-<%= a.asset_type %>"><%= a.asset_type.toUpperCase() %></span></td>
              <td class="num"><%= a.quantity %></td>
              <td class="num">$<%= fmt(a.buy_price) %></td>
              <td class="num cell-cur-price"><%= a.current_price != null ? '$' + fmt(a.current_price) : '—' %></td>
              <td class="num cell-cur-value"><%= a.current_value != null ? '$' + fmt(a.current_value) : '—' %></td>
              <td class="num cell-return-dollar <%= signClass(a.return_dollar) %>"><%= fmtDollar(a.return_dollar) %></td>
              <td class="num cell-return-pct <%= signClass(a.return_pct) %>"><%= fmtPct(a.return_pct) %></td>
              <td class="num cell-updated">
                <% if (a.last_updated) { %>
                  <%= new Date(a.last_updated).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %>
                <% } else { %>
                  —
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Allocation Chart -->
    <div class="card chart-card">
      <div class="card-header">
        <h2 class="card-title">Allocation</h2>
      </div>
      <div class="chart-wrapper">
        <canvas id="allocationChart"></canvas>
      </div>
      <ul class="chart-legend" id="chartLegend"></ul>
    </div>

  </section>

<% } %>

<!-- Bitcoin Wallets Section -->
<section class="wallets-section">
  <div class="card table-card">
    <div class="card-header">
      <h2 class="card-title">&#8383; Bitcoin Wallets</h2>
      <button class="btn btn-sm btn-primary" onclick="document.getElementById('wallet-form').classList.toggle('hidden')">+ Add Wallet</button>
    </div>

    <div id="wallet-form" class="wallet-add-form hidden">
      <form action="/wallet/add" method="POST" class="inline-form">
        <input type="text" name="label" class="form-input" placeholder="Label (e.g. Cold Wallet)" required />
        <input type="text" name="address" class="form-input" placeholder="Bitcoin address (bc1...)" required style="flex:2" />
        <button type="submit" class="btn btn-primary">Add</button>
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('wallet-form').classList.add('hidden')">Cancel</button>
      </form>
    </div>

    <% if (wallets.length === 0) { %>
      <p class="wallet-empty">No wallets tracked yet. Add a Bitcoin address above.</p>
    <% } else { %>
    <div class="table-wrapper">
      <table class="assets-table">
        <thead>
          <tr>
            <th></th>
            <th>Label</th>
            <th>Address</th>
            <th class="num">BTC Balance</th>
            <th class="num">Unconfirmed</th>
            <th class="num">USD Value</th>
            <th class="num">Updated</th>
          </tr>
        </thead>
        <tbody id="wallets-tbody">
          <% wallets.forEach(function(w) { %>
          <tr data-wallet-id="<%= w.id %>">
            <td class="action-col">
              <form action="/wallet/delete/<%= w.id %>" method="POST" onsubmit="return confirm('Remove <%= w.label %>?')" style="display:inline">
                <button type="submit" class="btn-delete" title="Remove">&#10005;</button>
              </form>
            </td>
            <td class="asset-name"><%= w.label %></td>
            <td><span class="wallet-addr"><%= w.address.slice(0,8) %>…<%= w.address.slice(-6) %></span></td>
            <td class="num cell-btc-balance"><%= w.btc_balance != null ? w.btc_balance.toFixed(8) : '—' %></td>
            <td class="num cell-btc-unconfirmed" style="color:var(--text-dim)"><%= w.btc_unconfirmed != null ? w.btc_unconfirmed.toFixed(8) : '—' %></td>
            <td class="num cell-wallet-usd"><%= w.usd_value != null ? '$' + w.usd_value.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}) : '—' %></td>
            <td class="num cell-wallet-updated" style="color:var(--text-dim)">
              <%= w.last_updated ? new Date(w.last_updated).toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit',second:'2-digit'}) : '—' %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</section>

<!-- Server data for chart (parsed by JS, not injected inline) -->
<script type="application/json" id="chartData"><%- JSON.stringify({ labels: chart.labels, values: chart.values }) %></script>

<!-- Chart.js from CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
  (function () {
    const chartData = JSON.parse(document.getElementById('chartData').textContent);
    const labels = chartData.labels;
    const values = chartData.values;

    if (!labels.length) return;

    const COLORS = [
      '#6c63ff', '#00e676', '#ff9100', '#00b0ff', '#ff4081',
      '#69f0ae', '#ffea00', '#40c4ff', '#ea80fc', '#ff6d00',
      '#b2ff59', '#f50057', '#18ffff', '#ffab40', '#e040fb'
    ];

    const ctx = document.getElementById('allocationChart');
    if (!ctx) return;

    const total = values.reduce((s, v) => s + v, 0);

    new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels,
        datasets: [{
          data: values,
          backgroundColor: COLORS.slice(0, labels.length),
          borderColor: '#0f0f14',
          borderWidth: 3,
          hoverOffset: 8,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: '62%',
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                const val = ctx.parsed;
                const pct = total > 0 ? ((val / total) * 100).toFixed(1) : 0;
                return ` $${val.toLocaleString('en-US', { minimumFractionDigits: 2 })} (${pct}%)`;
              }
            }
          }
        }
      }
    });

    // Custom legend
    const legend = document.getElementById('chartLegend');
    labels.forEach((label, i) => {
      const pct = total > 0 ? ((values[i] / total) * 100).toFixed(1) : 0;
      const li = document.createElement('li');
      li.innerHTML = `
        <span class="legend-dot" style="background:${COLORS[i % COLORS.length]}"></span>
        <span class="legend-label">${label}</span>
        <span class="legend-pct">${pct}%</span>
      `;
      legend.appendChild(li);
    });
  })();
</script>

<script>
(function () {
  function fmt(n) {
    return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function fmtDollar(n) {
    return (n >= 0 ? '+$' : '-$') + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function fmtPct(n) {
    return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
  }

  const liveStatus = document.getElementById('live-status');

  async function refreshPrices() {
    let data;
    try {
      const res = await fetch('/api/prices?t=' + Date.now());
      if (!res.ok) throw new Error('bad status ' + res.status);
      data = await res.json();
    } catch (e) {
      if (liveStatus) liveStatus.textContent = 'Error';
      setTimeout(refreshPrices, 2000);
      return;
    }

    let totalInvested = 0, totalValue = 0;

    document.querySelectorAll('tr[data-asset-id]').forEach(row => {
      const id = row.dataset.assetId;
      const entry = data[id];
      const buyPrice = parseFloat(row.dataset.buyPrice);
      const qty = parseFloat(row.dataset.quantity);
      const costBasis = qty * buyPrice;
      totalInvested += costBasis;

      if (!entry || entry.price == null) return;

      const price = entry.price;
      const curValue = qty * price;
      const retDollar = curValue - costBasis;
      const retPct = ((price - buyPrice) / buyPrice) * 100;
      totalValue += curValue;

      row.querySelector('.cell-cur-price').textContent = '$' + fmt(price);
      row.querySelector('.cell-cur-value').textContent = '$' + fmt(curValue);

      const rdCell = row.querySelector('.cell-return-dollar');
      rdCell.textContent = fmtDollar(retDollar);
      rdCell.className = 'num cell-return-dollar ' + (retDollar >= 0 ? 'positive' : 'negative');

      const rpCell = row.querySelector('.cell-return-pct');
      rpCell.textContent = fmtPct(retPct);
      rpCell.className = 'num cell-return-pct ' + (retPct >= 0 ? 'positive' : 'negative');

      row.querySelector('.cell-updated').textContent =
        new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    });

    // Store asset total value for combined update
    window._assetTotalValue = totalValue;
    window._assetTotalInvested = totalInvested;
    updatePortfolioSummary();

    if (liveStatus) liveStatus.textContent = new Date().toLocaleTimeString();
    setTimeout(refreshPrices, 2000);
  }

  function updatePortfolioSummary() {
    const assetValue = window._assetTotalValue || 0;
    const walletValue = window._walletTotalUsd || 0;
    const totalInvested = window._assetTotalInvested || 0;
    const combined = assetValue + walletValue;
    const totalReturn = assetValue - totalInvested;
    const totalReturnPct = totalInvested > 0 ? (totalReturn / totalInvested) * 100 : 0;

    const cardTotal = document.getElementById('card-total-value');
    const cardWallet = document.getElementById('card-wallet-value');
    const cardRetDollar = document.getElementById('card-return-dollar');
    const cardRetPct = document.getElementById('card-return-pct');

    if (cardTotal) cardTotal.textContent = '$' + fmt(combined);
    if (cardWallet) cardWallet.textContent = '$' + fmt(walletValue);
    if (cardRetDollar) {
      cardRetDollar.textContent = fmtDollar(totalReturn);
      cardRetDollar.className = 'card-value ' + (totalReturn >= 0 ? 'positive' : 'negative');
    }
    if (cardRetPct) {
      cardRetPct.textContent = fmtPct(totalReturnPct);
      cardRetPct.className = 'card-value ' + (totalReturnPct >= 0 ? 'positive' : 'negative');
    }
  }

  async function refreshWallets() {
    let data;
    try {
      const res = await fetch('/api/wallets?t=' + Date.now());
      if (!res.ok) throw new Error('bad status');
      data = await res.json();
    } catch (e) {
      setTimeout(refreshWallets, 10000);
      return;
    }

    let walletTotal = 0;
    data.forEach(w => {
      const row = document.querySelector(`tr[data-wallet-id="${w.id}"]`);
      if (!row) return;
      if (w.btc != null) row.querySelector('.cell-btc-balance').textContent = w.btc.toFixed(8);
      if (w.unconfirmed != null) row.querySelector('.cell-btc-unconfirmed').textContent = w.unconfirmed.toFixed(8);
      if (w.usd != null) {
        row.querySelector('.cell-wallet-usd').textContent = '$' + fmt(w.usd);
        walletTotal += w.usd;
      }
      row.querySelector('.cell-wallet-updated').textContent =
        new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    });

    window._walletTotalUsd = walletTotal;
    updatePortfolioSummary();
    setTimeout(refreshWallets, 10000);
  }

  window._assetTotalValue = 0;
  window._assetTotalInvested = 0;
  window._walletTotalUsd = 0;

  refreshPrices();
  refreshWallets();
})();
</script>

<%- include('partials/footer') %>
